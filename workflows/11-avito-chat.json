              "neverError": true
            }
          }
        }
      }
    },
    {
      "id": "av6b",
      "name": "Get Site Config",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1520,
        300
      ],
      "parameters": {
        "method": "GET",
        "url": "https://mycheagent.ru/webhook/site-config",
