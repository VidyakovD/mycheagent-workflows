    {
      "id": "av1",
      "name": "Avito Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        200,
        300
      ],
      "webhookId": "avito-messages-hook",
      "parameters": {
        "httpMethod": "POST",
        "path": "avito-messages",
