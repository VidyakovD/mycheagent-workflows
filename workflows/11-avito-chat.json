    {
      "id": "av7",
      "name": "Prepare GPT Body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1520,
        300
      ],
      "parameters": {
        "jsCode": "const ctx = $('Merge Context').first().json;\nconst msgs = ($('Get Chat History').first().json.messages || []).slice().reverse();\n\nconst conversation = msgs\n  .filter(m => m.content?.text)\n  .map(m => ({\n    role: String(m.author_id) === String(ctx.userId) ? 'assistant' : 'user',\n    content: m.content.text\n  }));\n\n// Ensure last message is from user\nif (!conversation.length || conversation[conversation.length-1].role !== 'user') {\n  conversation.push({ role: 'user', content: ctx.lastText });\n}\n\n// Item info (which ad they wrote from)\nconst itemData = $('Get Item Info').first().json;\nconst itemTitle = itemData.title || itemData.name || '';\nconst itemCategory = itemData.category?.name || '';\nconst itemLine = itemTitle ? `\\n\\nОБЪЯВЛЕНИЕ: Человек написал по объявлению «${itemTitle}»${itemCategory ? ' (категория: ' + itemCategory + ')' : ''}. Отвечай с учётом этого контекста.` : '';\n\n// Get shared config from site-chat workflow\nconst siteConf = $input.first().json;\nconst basePrompt = siteConf.basePrompt || 'Ты — ассистент платформы Студия ЧЕ по видеомонтажу и ИИ.';\nconst courses = siteConf.courses || [];\n\nconst coursesList = courses.map((c,i) => `${i+1}. \"${c.name}\" — ${c.price}${c.level ? ' ('+c.level+')' : ''}`).join('\\n');\n\nconst systemPrompt = basePrompt + '\\n\\nКУРСЫ НА ПЛАТФОРМЕ:\\n' + coursesList + itemLine + `\n\nДОПОЛНИТЕЛЬНЫЕ ПРАВИЛА ДЛЯ АВИТО:\n- Отвечай кратко (2-3 предложения), как живой эксперт, не как продавец\n- НЕ навязывай курсы и не зови на сайт без явного запроса\n- Если человек спрашивает про тему — помогай по существу\n- Добавь SEND_SITE_LINK в самый конец ответа ТОЛЬКО если человек явно выразил желание учиться/купить/записаться. Триггеры: хочу записаться, хочу попробовать, хочу поучиться, хочу начать, хочу купить, хочу курс, интересует курс, как записаться, как купить, как оплатить, где ссылка, сколько стоит, готов учиться, давайте начнём, давайте попробуем, запишите меня, расскажи подробнее о курсе, что входит в курс, как проходит обучение, есть ли рассрочка, когда старт, можно ли купить, беру, покупаю, оформляю\n- Не выдумывай цены и курсы которых нет в списке`;\n\nconst body = JSON.stringify({\n  model: 'gpt-4o-mini',\n  messages: [{ role: 'system', content: systemPrompt }, ...conversation],\n  max_tokens: 200\n});\n\nreturn [{ json: { gptBody: body, token: ctx.token, userId: ctx.userId, chatId: ctx.chatId, msgId: ctx.msgId } }];"
      }
    },
    {
