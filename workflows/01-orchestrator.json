{
  "name": "01-orchestrator",
  "id": "orchestrator-001",
  "active": true,
  "settings": { "executionOrder": "v1" },
  "nodes": [
    {
      "id": "n1",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [200, 300],
      "webhookId": "mycheagent-main-bot",
      "parameters": {
        "updates": ["message"],
        "additionalFields": {}
      },
      "credentials": {
        "telegramApi": {
          "id": "fbg2O80BR8u1tCRB",
          "name": "Telegram account"
        }
      }
    },
    {
      "id": "n2",
      "name": "Router",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 300],
      "parameters": {
        "jsCode": "const msg = $input.first().json?.message;\nif (!msg) return [];\n\nconst chatId = msg.chat.id;\nconst isVoice = !!msg.voice;\nconst isText = !!msg.text;\n\nif (!isVoice && !isText) return [];\n\nreturn [{\n  json: {\n    chatId,\n    isVoice,\n    text: msg.text || '',\n    fileId: isVoice ? msg.voice.file_id : null\n  }\n}];"
      }
    },
    {
      "id": "n3",
      "name": "Is Voice?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [640, 300],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [{
            "id": "c1",
            "leftValue": "={{ $json.isVoice }}",
            "rightValue": true,
            "operator": { "type": "boolean", "operation": "true" }
          }],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "n4",
      "name": "Get TG File",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [860, 160],
      "parameters": {
        "url": "={{ 'https://api.telegram.org/bot' + $env.TELEGRAM_BOT_TOKEN + '/getFile?file_id=' + $json.fileId }}",
        "options": {}
      }
    },
    {
      "id": "n5",
      "name": "Download Voice",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1080, 160],
      "parameters": {
        "url": "={{ 'https://api.telegram.org/file/bot' + $env.TELEGRAM_BOT_TOKEN + '/' + $json.result.file_path }}",
        "options": {
          "response": {
            "response": { "responseFormat": "file", "outputPropertyName": "data" }
          }
        }
      }
    },
    {
      "id": "n6",
      "name": "Whisper",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1300, 160],
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/audio/transcriptions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "={{ 'Bearer ' + $env.OPENAI_API_KEY }}" }
          ]
        },
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            { "name": "model", "value": "whisper-1", "parameterType": "formData" },
            { "name": "language", "value": "ru", "parameterType": "formData" },
            { "name": "file", "value": "data", "parameterType": "formBinaryData", "inputDataFieldName": "data" }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "n7",
      "name": "Prep Voice",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1520, 160],
      "parameters": {
        "jsCode": "const chatId = $('Router').item.json.chatId;\nconst text = $input.first().json.text;\nreturn [{ json: { chatId, userText: text, isVoice: true } }];"
      }
    },
    {
      "id": "n8",
      "name": "Prep Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [860, 440],
      "parameters": {
        "jsCode": "const d = $input.first().json;\nreturn [{ json: { chatId: d.chatId, userText: d.text, isVoice: false } }];"
      }
    },
    {
      "id": "n9",
      "name": "GPT",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1740, 300],
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "={{ 'Bearer ' + $env.OPENAI_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ model: 'gpt-4o-mini', messages: [{ role: 'system', content: 'Ты умный персональный ассистент по имени Зевс. Отвечай кратко, по-русски, дружелюбно.' }, { role: 'user', content: $json.userText }] }) }}",
        "options": {}
      }
    },
    {
      "id": "n10",
      "name": "Build Reply",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1960, 300],
      "parameters": {
        "jsCode": "const gpt = $input.first().json;\nconst text = gpt.choices?.[0]?.message?.content || 'Не удалось получить ответ';\nconst chatId = $('Router').item.json.chatId;\nconst isVoice = $('Router').item.json.isVoice;\nreturn [{ json: { chatId, text, isVoice } }];"
      }
    },
    {
      "id": "n11",
      "name": "Reply Voice?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [2180, 300],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [{
            "id": "c2",
            "leftValue": "={{ $json.isVoice }}",
            "rightValue": true,
            "operator": { "type": "boolean", "operation": "true" }
          }],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "n12",
      "name": "TTS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2400, 160],
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/audio/speech",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "={{ 'Bearer ' + $env.OPENAI_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ model: 'tts-1', input: $json.text, voice: 'nova', response_format: 'mp3' }) }}",
        "options": {
          "response": {
            "response": { "responseFormat": "file", "outputPropertyName": "data" }
          }
        }
      }
    },
    {
      "id": "n13",
      "name": "Send Voice",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2620, 160],
      "parameters": {
        "method": "POST",
        "url": "={{ 'https://api.telegram.org/bot' + $env.TELEGRAM_BOT_TOKEN + '/sendVoice' }}",
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            { "name": "chat_id", "value": "={{ $('Build Reply').item.json.chatId }}", "parameterType": "formData" },
            { "name": "voice", "value": "data", "parameterType": "formBinaryData", "inputDataFieldName": "data" }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "n14",
      "name": "Send Text",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2400, 440],
      "parameters": {
        "method": "POST",
        "url": "={{ 'https://api.telegram.org/bot' + $env.TELEGRAM_BOT_TOKEN + '/sendMessage' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ chat_id: $json.chatId, text: $json.text }) }}",
        "options": {}
      }
    }
  ],
  "connections": {
    "Telegram Trigger": { "main": [[{ "node": "Router", "type": "main", "index": 0 }]] },
    "Router":           { "main": [[{ "node": "Is Voice?", "type": "main", "index": 0 }]] },
    "Is Voice?":        { "main": [
                            [{ "node": "Get TG File", "type": "main", "index": 0 }],
                            [{ "node": "Prep Text",   "type": "main", "index": 0 }]
                         ]},
    "Get TG File":      { "main": [[{ "node": "Download Voice", "type": "main", "index": 0 }]] },
    "Download Voice":   { "main": [[{ "node": "Whisper",        "type": "main", "index": 0 }]] },
    "Whisper":          { "main": [[{ "node": "Prep Voice",     "type": "main", "index": 0 }]] },
    "Prep Voice":       { "main": [[{ "node": "GPT",            "type": "main", "index": 0 }]] },
    "Prep Text":        { "main": [[{ "node": "GPT",            "type": "main", "index": 0 }]] },
    "GPT":              { "main": [[{ "node": "Build Reply",    "type": "main", "index": 0 }]] },
    "Build Reply":      { "main": [[{ "node": "Reply Voice?",   "type": "main", "index": 0 }]] },
    "Reply Voice?":     { "main": [
                            [{ "node": "TTS",       "type": "main", "index": 0 }],
                            [{ "node": "Send Text", "type": "main", "index": 0 }]
                         ]},
    "TTS":              { "main": [[{ "node": "Send Voice", "type": "main", "index": 0 }]] }
  }
}
