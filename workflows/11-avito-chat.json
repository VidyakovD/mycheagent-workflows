      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2620,
        160
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ 'https://api.avito.ru/messenger/v2/accounts/' + $('Extract Reply').item.json.userId + '/chats/' + $('Extract Reply').item.json.chatId + '/messages' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ 'Bearer ' + $('Extract Reply').item.json.token }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ message: { text: '🎓 Записаться и посмотреть все программы: studiyache.ru\\n\\nДоступ навсегда после оплаты, без подписок 💪' }, type: 'text' }) }}"
      }
    },
    {
      "id": "av13",
      "name": "Mark Replied",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2840,
        300
      ],
      "parameters": {
        "jsCode": "const ctx = $('Extract Reply').first().json;\nconst store = $getWorkflowStaticData('global');\nif (!store.replied) store.replied = {};\nstore.replied[ctx.chatId] = ctx.msgId;\nconst keys = Object.keys(store.replied);\nif (keys.length > 500) {\n  keys.slice(0, keys.length - 500).forEach(k => delete store.replied[k]);\n}\nreturn [{ json: { ok: true } }];"
      }
    }
  ],
