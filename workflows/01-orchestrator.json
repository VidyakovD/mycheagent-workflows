{
  "name": "01-orchestrator",
  "nodes": [
    {
      "parameters": {
        "updates": ["message"],
        "additionalFields": {}
      },
      "id": "n1",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [200, 300],
      "webhookId": "mycheagent-main-bot",
      "credentials": {
        "telegramApi": {
          "id": "yhUMiv9LjfkcOqFE",
          "name": "Telegram account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const msg = $input.first().json?.message;\nif (!msg) return [];\n\nconst isVoice = !!msg.voice;\nconst isText  = !!msg.text;\nif (!isVoice && !isText) return [];\n\nreturn [{ json: {\n  chatId:   msg.chat.id,\n  userId:   msg.from?.id,\n  username: msg.from?.first_name || 'Пользователь',\n  isVoice,\n  text:     msg.text || '',\n  fileId:   isVoice ? msg.voice.file_id : null\n}}];"
      },
      "id": "n2",
      "name": "Parse Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [{
            "id": "voice-check",
            "leftValue": "={{ $json.isVoice }}",
            "rightValue": true,
            "operator": { "type": "boolean", "operation": "true" }
          }],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "n3",
      "name": "Is Voice?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [640, 300]
    },
    {
      "parameters": {
        "url": "={{ 'https://api.telegram.org/bot' + $env.TELEGRAM_BOT_TOKEN + '/getFile' }}",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [{ "name": "file_id", "value": "={{ $json.fileId }}" }]
        },
        "options": {}
      },
      "id": "n4",
      "name": "Get File URL",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [860, 140]
    },
    {
      "parameters": {
        "url": "={{ 'https://api.telegram.org/file/bot' + $env.TELEGRAM_BOT_TOKEN + '/' + $json.result.file_path }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "file",
              "outputPropertyName": "data"
            }
          }
        }
      },
      "id": "n5",
      "name": "Download Audio",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1080, 140]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/audio/transcriptions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "={{ 'Bearer ' + $env.OPENAI_API_KEY }}" }
          ]
        },
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            { "name": "model",    "value": "whisper-1",        "parameterType": "formData" },
            { "name": "language", "value": "ru",               "parameterType": "formData" },
            { "name": "file",     "value": "data",             "parameterType": "formBinaryData",
              "inputDataFieldName": "data" }
          ]
        },
        "options": {}
      },
      "id": "n6",
      "name": "Whisper STT",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1300, 140]
    },
    {
      "parameters": {
        "jsCode": "const whisper = $input.first().json;\nconst src = $('Parse Message').item.json;\nreturn [{ json: {\n  userText: whisper.text,\n  chatId:   src.chatId,\n  isVoice:  true\n}}];"
      },
      "id": "n7",
      "name": "Set Voice Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1520, 140]
    },
    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nreturn [{ json: {\n  userText: d.text,\n  chatId:   d.chatId,\n  isVoice:  false\n}}];"
      },
      "id": "n8",
      "name": "Set Text Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [860, 460]
    },
    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nconst body = JSON.stringify({\n  model: 'gpt-4o-mini',\n  messages: [\n    { role: 'system', content: 'Ты умный персональный ассистент по имени Мичи. Отвечай кратко, по-русски, дружелюбно. Помогаешь с вопросами, задачами и напоминаниями.' },\n    { role: 'user', content: d.userText }\n  ]\n});\nreturn [{ json: { ...d, claudeBody: body }}];"
      },
      "id": "n9",
      "name": "Build Claude Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1740, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "={{ 'Bearer ' + $env.OPENAI_API_KEY }}" },
            { "name": "Content-Type",  "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ $json.claudeBody }}",
        "options": {}
      },
      "id": "n10",
      "name": "Claude",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1960, 300]
    },
    {
      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst text = resp.choices?.[0]?.message?.content || '⚠️ Не удалось получить ответ';\nconst src = $('Build Claude Request').item.json;\nreturn [{ json: { chatId: src.chatId, isVoice: src.isVoice, text }}];"
      },
      "id": "n11",
      "name": "Extract Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2180, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [{
            "id": "reply-voice-check",
            "leftValue": "={{ $json.isVoice }}",
            "rightValue": true,
            "operator": { "type": "boolean", "operation": "true" }
          }],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "n12",
      "name": "Reply as Voice?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [2400, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/audio/speech",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "={{ 'Bearer ' + $env.OPENAI_API_KEY }}" }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ model: 'tts-1', input: $json.text, voice: 'nova', response_format: 'mp3' }) }}",
        "options": {
          "response": { "response": { "responseFormat": "file" } }
        }
      },
      "id": "n13",
      "name": "OpenAI TTS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2620, 160]
    },
    {
      "parameters": {
        "jsCode": "const chatId = $('Extract Response').item.json.chatId;\nconst binaryData = $input.first().binary?.data;\nif (!binaryData) throw new Error('No audio binary data');\n\nconst audioBuffer = Buffer.from(binaryData.data, 'base64');\nconst boundary = '----n8nboundary' + Date.now();\n\nlet body = Buffer.concat([\n  Buffer.from(`--${boundary}\\r\\nContent-Disposition: form-data; name=\"chat_id\"\\r\\n\\r\\n${chatId}\\r\\n`),\n  Buffer.from(`--${boundary}\\r\\nContent-Disposition: form-data; name=\"audio\"; filename=\"voice.mp3\"\\r\\nContent-Type: audio/mpeg\\r\\n\\r\\n`),\n  audioBuffer,\n  Buffer.from(`\\r\\n--${boundary}--\\r\\n`)\n]);\n\nconst token = $env.TELEGRAM_BOT_TOKEN;\nconst https = require('https');\n\nawait new Promise((resolve, reject) => {\n  const options = {\n    hostname: 'api.telegram.org',\n    path: `/bot${token}/sendAudio`,\n    method: 'POST',\n    headers: {\n      'Content-Type': `multipart/form-data; boundary=${boundary}`,\n      'Content-Length': body.length\n    }\n  };\n  const req = https.request(options, (res) => {\n    let data = '';\n    res.on('data', chunk => data += chunk);\n    res.on('end', () => resolve(JSON.parse(data)));\n  });\n  req.on('error', reject);\n  req.write(body);\n  req.end();\n});\n\nreturn [{ json: { ok: true } }];"
      },
      "id": "n14",
      "name": "Send Voice Reply",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2840, 160]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ 'https://api.telegram.org/bot' + $env.TELEGRAM_BOT_TOKEN + '/sendMessage' }}",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ chat_id: $json.chatId, text: $json.text }) }}",
        "options": {}
      },
      "id": "n15",
      "name": "Send Text Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2620, 460]
    }
  ],
  "connections": {
    "Telegram Trigger":     { "main": [[{ "node": "Parse Message",        "type": "main", "index": 0 }]] },
    "Parse Message":        { "main": [[{ "node": "Is Voice?",             "type": "main", "index": 0 }]] },
    "Is Voice?":            { "main": [
                                [{ "node": "Get File URL",    "type": "main", "index": 0 }],
                                [{ "node": "Set Text Input",  "type": "main", "index": 0 }]
                             ]},
    "Get File URL":         { "main": [[{ "node": "Download Audio",        "type": "main", "index": 0 }]] },
    "Download Audio":       { "main": [[{ "node": "Whisper STT",           "type": "main", "index": 0 }]] },
    "Whisper STT":          { "main": [[{ "node": "Set Voice Input",       "type": "main", "index": 0 }]] },
    "Set Voice Input":      { "main": [[{ "node": "Build Claude Request",  "type": "main", "index": 0 }]] },
    "Set Text Input":       { "main": [[{ "node": "Build Claude Request",  "type": "main", "index": 0 }]] },
    "Build Claude Request": { "main": [[{ "node": "Claude",                "type": "main", "index": 0 }]] },
    "Claude":               { "main": [[{ "node": "Extract Response",      "type": "main", "index": 0 }]] },
    "Extract Response":     { "main": [[{ "node": "Reply as Voice?",       "type": "main", "index": 0 }]] },
    "Reply as Voice?":      { "main": [
                                [{ "node": "OpenAI TTS",      "type": "main", "index": 0 }],
                                [{ "node": "Send Text Reply", "type": "main", "index": 0 }]
                             ]},
    "OpenAI TTS":           { "main": [[{ "node": "Send Voice Reply",      "type": "main", "index": 0 }]] }
  },
  "active": true,
  "settings": { "executionOrder": "v1" },
  "id": "orchestrator-001"
}
