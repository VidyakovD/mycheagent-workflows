    {
      "id": "av2",
      "name": "Parse Incoming",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        420,
        300
      ],
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst body = raw.body || raw;\n\n// Avito v3.0.0 wraps in payload.value\nconst payload = body.payload || body;\nconst value = payload.value || body.value || body;\n\n// Skip non-text/non-message types\nif (payload.type && payload.type !== 'message') {\n  return [{ json: { skip: true, reason: 'not a message: ' + payload.type } }];\n}\nif (value.type && value.type !== 'text') {\n  return [{ json: { skip: true, reason: 'not text: ' + value.type } }];\n}\n\nconst chatId = value.chat_id || value.chatId || '';\nconst authorId = String(value.author_id || value.authorId || '');\nconst msgId = value.id || '';\nconst text = value.content?.text || value.text || '';\nconst itemId = String(value.item_id || value.itemId || body.item_id || '');\n\nif (!chatId || !text) {\n  return [{ json: { skip: true, reason: 'no chatId or text', debug: JSON.stringify(body).slice(0,500) } }];\n}\n\nreturn [{ json: { chatId, authorId, msgId, text, itemId, skip: false } }];"
      }
    },
