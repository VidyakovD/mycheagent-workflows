        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ $json.gptBody }}"
      }
    },
    {
      "id": "av9",
      "name": "Extract Reply",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1960,
        300
      ],
      "parameters": {
        "jsCode": "const gptRes = $input.first().json;\nconst prev = $('Prepare GPT Body').first().json;\nlet reply = gptRes.choices?.[0]?.message?.content?.trim() || 'Добрый день! Чем могу помочь? 😊';\n\nconst sendLink = reply.includes('SEND_SITE_LINK');\nreply = reply.replace('SEND_SITE_LINK', '').trim();\n\nreturn [{ json: { reply, sendLink, token: prev.token, userId: prev.userId, chatId: prev.chatId, msgId: prev.msgId } }];"
      }
    },
