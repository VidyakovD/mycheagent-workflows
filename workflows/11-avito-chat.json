      ],
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://api.avito.ru/messenger/v2/accounts/' + $json.userId + '/chats/' + $json.chatId + '/messages?limit=10' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ 'Bearer ' + $json.token }}"
            }
          ]
        }
      }
    },
