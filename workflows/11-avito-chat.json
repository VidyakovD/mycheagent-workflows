    {
      "id": "av4",
      "name": "Get Self",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        860,
        300
      ],
      "parameters": {
        "method": "GET",
        "url": "https://api.avito.ru/core/v1/accounts/self",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ 'Bearer ' + $json.access_token }}"
            }
          ]
        }
      }
    },
    {
      "id": "av5",
      "name": "Merge Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1080,
        300
      ],
      "parameters": {
        "jsCode": "const token = $('Get Token').first().json.access_token;\nconst userId = String($input.first().json.id);\nconst parsed = $('Parse Incoming').first().json;\n\n// Don't reply to our own messages\nif (parsed.authorId === userId) {\n  return [{ json: { skip: true, reason: 'own message' } }];\n}\n\n// Dedup: don't reply to same message twice\nconst store = $getWorkflowStaticData('global');\nif (!store.replied) store.replied = {};\nif (store.replied[parsed.chatId] === parsed.msgId) {\n  return [{ json: { skip: true, reason: 'already replied' } }];\n}\n\nreturn [{ json: { skip: false, token, userId, chatId: parsed.chatId, msgId: parsed.msgId, lastText: parsed.text, itemId: parsed.itemId || '' } }];"
      }
    },
    {
